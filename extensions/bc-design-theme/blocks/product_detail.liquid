<!-- BC DEBUG: custom_enabled = {{ product.metafields.bc_design.enabled.value | json }}, template.name = {{ template.name }} -->
<script>
  console.log('%c[BC Design] App Block initialized. custom.enabled = %o, template.name = %o', 'color: #008060; font-weight: bold;', {{ product.metafields.bc_design.enabled.value | json }}, {{ template.name | json }});
</script>
{% assign custom_enabled = product.metafields.bc_design.enabled.value %}
{% assign config = product.metafields['$app'].product_detail_config.value %}

{% assign should_render = false %}
{% if custom_enabled == true %}
  {% assign should_render = true %}
{% endif %}

{% unless template.name == 'product' and should_render %}
{% else %}

{% assign three_d_image = product.metafields.bc_design.three_d_image.value %}
{% assign parts_image = product.metafields.bc_design.parts_image.value %}
{% assign product_video = product.metafields.bc_design.video.value %}
{% assign product_video_url = product.metafields.bc_design.video_url.value %}

<style>
  #shopify-block-{{ block.id }} {
    width: 100vw;
    max-width: 100vw;
    margin-left: calc(50% - 50vw);
    margin-right: calc(50% - 50vw);
  }
  .bc-design-embed--pending { visibility: hidden; }

  /* Hide original Shopify theme product section */
  section:has(.product__info-container),
  section:has(.product-single),
  .shopify-section-main-product,
  #shopify-section-main-product {
    display: none !important;
  }

  /* Limit rating stars image sizing */
  .bc-product-subtitle-row img {
    width: clamp(14px, 1.167vw, 28px) !important;
    height: clamp(14px, 1.167vw, 28px) !important;
    object-fit: contain !important;
  }
</style>

<div
  data-bc-design-embed="product-detail"
  class="bc-design-embed--pending"
  {{ block.shopify_attributes }}
>
  <script type="application/json" data-bc-pd-data>
    {
      "variants": [
        {% for v in product.variants %}
        {% assign v_has_compare = false %}
        {% if v.compare_at_price > v.price %}
          {% assign v_has_compare = true %}
        {% endif %}
        {%- capture v_compare_html -%}{% if v_has_compare %}{{ v.compare_at_price | money }}{% endif %}{%- endcapture -%}
        {%- capture v_save_html -%}{% if v_has_compare %}Save {{ v.compare_at_price | minus: v.price | money }}{% endif %}{%- endcapture -%}
        {
          "id": {{ v.id | json }},
          "options": {{ v.options | json }},
          "available": {{ v.available | json }},
          "priceHtml": {{ v.price | money | json }},
          "hasCompareAt": {{ v_has_compare | json }},
          "compareAtHtml": {{ v_compare_html | json }},
          "saveHtml": {{ v_save_html | json }}
        }{% unless forloop.last %},{% endunless %}
        {% endfor %}
      ],
      "options": {{ product.options | json }},
      "config": {{ config | json }}
    }
  </script>

  <main class="bc-product-detail container-fluid">
    <div class="bc-product-detail__inner">

      <!-- ═══════════════════════════════════════════════════
           LEFT: Product Image Stage
           ═══════════════════════════════════════════════════ -->
      <section class="bc-product-detail__media">
        <!-- Image Stage -->
        <div class="product-image-stage">

          <!-- 1. 3D & Featured Image Panel -->
          <div class="bc-stage-content bc-stage-content--active" data-stage-content="3d">
            <!-- 360° Badge (top-left) -->
            <div class="bc-badge-360">
              <img
                src="{{ 'badge-3d.png' | asset_url }}"
                alt="3D View"
              >
            </div>

            <!-- Product Hero Image + 360° Play Button -->
            <div class="product-hero-container">
              {% if three_d_image != blank %}
                <img
                  src="{{ three_d_image | image_url: width: 1200 }}"
                  class="product-hero-img"
                  alt="{{ product.title | escape }}"
                >
              {% elsif product.featured_image %}
                <img
                  src="{{ product.featured_image | image_url: width: 1200 }}"
                  class="product-hero-img"
                  alt="{{ product.title | escape }}"
                >
              {% else %}
                <div class="bc-product-media__placeholder absolute top-0 left-0 w-[83%] h-full bg-bc-pd-border/30" aria-hidden="true"></div>
              {% endif %}

              <!-- 360° Play Button -->
              <button
                type="button"
                class="bc-play-btn"
                aria-label="Play 360° view"
              >
                <img
                  src="{{ 'btn-play.png' | asset_url }}"
                  alt="Play"
                >
              </button>
            </div>

            <!-- Zoom Button (bottom-right) -->
            <button
              type="button"
              class="bc-zoom-btn"
              aria-label="Zoom image"
            >
              <img
                src="{{ 'btn-zoom.png' | asset_url }}"
                alt="Zoom"
              >
            </button>
          </div>

          <!-- 2. Parts Image Panel -->
          {% if parts_image != blank %}
            <div class="bc-stage-content" data-stage-content="parts">
              <div class="product-hero-container" style="width: 100%; height: 100%; top: 0; left: 0;">
                <img
                  src="{{ parts_image | image_url: width: 1200 }}"
                  class="product-hero-img"
                  style="width: 100%; height: 100%; object-fit: contain;"
                  alt="Parts List"
                >
              </div>
            </div>
          {% endif %}

          <!-- 3. Video Panel -->
          {% if product_video != blank or product_video_url != blank %}
            <div class="bc-stage-content" data-stage-content="video">
              <div class="product-hero-container" style="width: 100%; height: 100%; top: 0; left: 0;">
                {% if product_video != blank %}
                  {{ product_video | video_tag: autoplay: true, loop: true, muted: true, controls: true, class: "product-hero-img", style: "width: 100%; height: 100%; object-fit: contain;" }}
                {% else %}
                  <video
                    src="{{ product_video_url }}"
                    autoplay
                    loop
                    muted
                    controls
                    class="product-hero-img"
                    style="width: 100%; height: 100%; object-fit: contain;"
                  ></video>
                {% endif %}
              </div>
            </div>
          {% endif %}

        </div>

        <!-- Bottom Action Pills -->
        <div class="bc-product-media__tabs">
          <button type="button" class="bc-tab bc-tab--active" data-tab="3d" style="width: clamp(103px, 8.58vw, 206px); height: clamp(54px, 4.5vw, 108px);">
            <img src="{{ 'tab-3d.png' | asset_url }}" style="width: clamp(20px, 1.67vw, 40px); height: clamp(20px, 1.67vw, 40px); object-fit: contain;" alt="">
            <span class="text-lg whitespace-nowrap">3D</span>
          </button>
          {% if parts_image != blank %}
            <button type="button" class="bc-tab" data-tab="parts" style="width: clamp(146px, 12.17vw, 292px); height: clamp(54px, 4.5vw, 108px);">
              <img src="{{ 'tab-parts.png' | asset_url }}" style="width: clamp(20px, 1.67vw, 40px); height: clamp(20px, 1.67vw, 40px); object-fit: contain;" alt="">
              <span class="text-lg whitespace-nowrap">物品清单</span>
            </button>
          {% endif %}
          {% if product_video != blank or product_video_url != blank %}
            <button type="button" class="bc-tab" data-tab="video" style="width: clamp(128px, 10.67vw, 256px); height: clamp(54px, 4.5vw, 108px);">
              <img src="{{ 'tab-video.png' | asset_url }}" style="width: clamp(24px, 2vw, 48px); height: clamp(15px, 1.25vw, 30px); object-fit: contain;" alt="">
              <span class="text-lg whitespace-nowrap">Video</span>
            </button>
          {% endif %}
        </div>
      </section>

      <!-- ═══════════════════════════════════════════════════
           RIGHT: Product Information
           ═══════════════════════════════════════════════════ -->
      <section class="bc-product-detail__info">
        <form class="bc-product-form" data-variant-id="{{ product.selected_or_first_available_variant.id }}" data-add-to-cart-text="Add to cart">
          
          <!-- Product Title -->
          <h1 class="bc-product-title">
            {{ product.title }}
          </h1>

          <!-- Rating Row -->
          {% assign custom_subtitle = product.metafields.bc_design.subtitle.value %}
          {% assign custom_rating = product.metafields.bc_design.rating.value %}
          {% assign custom_features = product.metafields.bc_design.features.value %}
          
          <div class="bc-product-subtitle-row">
            <span>{{ custom_subtitle | default: 'Conch Hotend™' }}</span>
            <div>
              <span class="bc-rating">{{ custom_rating | default: '4.9' }}</span>
              <img
                src="{{ 'icon-star.png' | asset_url }}"
                alt="Rating star"
              >
            </div>
          </div>

          <!-- Features Card -->
          {% if custom_features != blank and custom_features.size > 0 %}
            <div class="bc-features-card">
              <h2>Features</h2>
              <ul>
                {% for feature in custom_features %}
                  <li>{{ feature }}</li>
                {% endfor %}
              </ul>
            </div>
          {% else %}
            <!-- Fallback Features card based on prototype -->
            <div class="bc-features-card">
              <h2>Features</h2>
              <ul>
                <li>EndCoat Ultra-wear resistant coating nozzle</li>
                <li>Heat block is made of copper material</li>
                <li>500C degree high temperature resistance</li>
                <li>Fast heat conduction</li>
                <li>Ultimate Cooling Design Radiator Heatsink</li>
              </ul>
            </div>
          {% endif %}

          <!-- Variant Options -->
          {% for option in product.options_with_values %}
            <div class="bc-option-group" data-option-name="{{ option.name | escape }}">
              <h2>{{ option.name }}</h2>
              <div class="bc-option-pills">
                {% for value in option.values %}
                  {% assign val_str = value.value | default: value.name | default: value %}
                  {% assign icon_filename = nil %}
                  {% for icon in config.optionIcons %}
                    {% if icon.optionName == option.name and icon.optionValue == val_str %}
                      {% assign icon_filename = icon.iconFilename %}
                    {% endif %}
                  {% endfor %}

                  <!-- Match icons for Nozzle Diameter automatically if icon_filename is empty -->
                  {% if icon_filename == blank and option.name == 'Nozzle Diameter' or option.name == 'nozzle diameter' %}
                    {% if val_str contains '0.2' %}
                      {% assign icon_filename = 'icon-nozzle-02.png' %}
                    {% elsif val_str contains '0.4' %}
                      {% assign icon_filename = 'icon-nozzle-04.png' %}
                    {% elsif val_str contains '0.6' %}
                      {% assign icon_filename = 'icon-nozzle-06.png' %}
                    {% elsif val_str contains '0.8' %}
                      {% assign icon_filename = 'icon-nozzle-08.png' %}
                    {% endif %}
                  {% endif %}

                  {% assign pill_active_class = "" %}
                  {% if value.selected %}
                    {% assign pill_active_class = "bc-option-pill--active" %}
                  {% endif %}
                  <button
                    type="button"
                    class="bc-option-pill {{ pill_active_class }}"
                    data-value="{{ val_str | escape }}"
                    {% unless value.available %}disabled data-disabled="true"{% endunless %}
                    style="width: clamp(107.5px, 8.96vw, 215px); height: clamp(42px, 3.5vw, 84px);"
                  >
                    {% if icon_filename != blank %}
                      {% if icon_filename contains 'png' %}
                        <img src="{{ icon_filename | asset_url }}" alt="">
                      {% else %}
                        <img src="{{ icon_filename | file_url }}" alt="">
                      {% endif %}
                    {% endif %}
                    <span>{{ val_str }}</span>
                  </button>
                {% endfor %}
              </div>
            </div>
          {% endfor %}

          <!-- Quantity -->
          <div class="bc-quantity-row">
            <span>Quantity</span>
            <div class="bc-qty-stepper">
              <button
                type="button"
                class="bc-qty-btn bc-qty-minus"
                aria-label="Decrease quantity"
              >
                <img src="{{ 'icon-minus.png' | asset_url }}" alt="-">
              </button>
              <span class="bc-qty-value">1</span>
              <button
                type="button"
                class="bc-qty-btn bc-qty-plus"
                aria-label="Increase quantity"
              >
                <img src="{{ 'icon-plus.png' | asset_url }}" alt="+">
              </button>
            </div>
          </div>

          <!-- Price Row -->
          <div class="bc-price-row">
            <span class="bc-price-current" data-current-price>
              {{ product.selected_or_first_available_variant.price | money }}
            </span>
            
            {% assign selected_variant = product.selected_or_first_available_variant %}
            {% assign has_compare = false %}
            {% if selected_variant.compare_at_price > selected_variant.price %}
              {% assign has_compare = true %}
            {% endif %}
            
            <span class="bc-price-save" data-save-price {% unless has_compare %}style="display:none;"{% endunless %}>
              {% if has_compare %}Save {{ selected_variant.compare_at_price | minus: selected_variant.price | money }}{% endif %}
            </span>
            
            <span class="bc-price-compare" data-compare-price {% unless has_compare %}style="display:none;"{% endunless %}>
              {% if has_compare %}{{ selected_variant.compare_at_price | money }}{% endif %}
            </span>
          </div>

          <!-- Add to Cart -->
          <button
            type="button"
            class="bc-add-to-cart"
            {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
          >
            Add to cart
          </button>
        </form>
      </section>
    </div>
  </main>
</div>

<script>
(function () {
  var embed = document.querySelector('[data-bc-design-embed="product-detail"]');
  if (!embed) return;
  var timer = setTimeout(function () {
    embed.classList.remove('bc-design-embed--pending');
  }, 3000);
  embed.dataset.bcDesignRevealFallback = String(timer);
})();
</script>
<script src="{{ 'product-detail.js' | asset_url }}" defer></script>
<script src="{{ 'bc-design-embed-placement.js' | asset_url }}" defer></script>

{% endunless %}

{% schema %}
{
  "name": "t:blocks.product_detail.name",
  "target": "body",
  "stylesheet": "product-detail.css",
  "settings": [
    {
      "type": "paragraph",
      "content": "Configure in Apps → BC Design → Product Detail. Renders only on product pages with enabled config."
    }
  ]
}
{% endschema %}
{% comment %}sync{% endcomment %}
