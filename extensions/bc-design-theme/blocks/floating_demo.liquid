<div
  id="bc-floating-demo-{{ block.id }}"
  class="bc-floating-demo bc-floating-demo--{{ block.settings.position }}"
  style="--bc-primary: {{ block.settings.primary_color }};"
>
  <button
    type="button"
    class="bc-floating-demo__toggle"
    aria-expanded="false"
    aria-controls="bc-floating-demo-panel-{{ block.id }}"
  >
  <span class="bc-floating-demo__toggle-icon" aria-hidden="true">💬</span>
    {{ block.settings.button_label }}
  </button>

  <div
    id="bc-floating-demo-panel-{{ block.id }}"
    class="bc-floating-demo__panel"
    hidden
  >
    <p class="bc-floating-demo__greeting">{{ block.settings.greeting }}</p>
    <p class="bc-floating-demo__meta">
      {{ 'floating_demo.store_label' | t }}: {{ shop.name }}
    </p>
    <p class="bc-floating-demo__meta">
      {{ 'floating_demo.page_label' | t }}: {{ request.page_type }}
    </p>
  </div>
</div>

{% schema %}
{
  "name": "Floating Demo",
  "target": "body",
  "stylesheet": "floating-demo.css",
  "javascript": "floating-demo.js",
  "settings": [
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Chat"
    },
    {
      "type": "textarea",
      "id": "greeting",
      "label": "Greeting message",
      "default": "Hello! This is a body-targeted app embed demo."
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary color",
      "default": "#5c6ac4"
    },
    {
      "type": "select",
      "id": "position",
      "label": "Position",
      "default": "bottom-right",
      "options": [
        { "value": "bottom-right", "label": "Bottom right" },
        { "value": "bottom-left", "label": "Bottom left" }
      ]
    }
  ]
}
{% endschema %}
