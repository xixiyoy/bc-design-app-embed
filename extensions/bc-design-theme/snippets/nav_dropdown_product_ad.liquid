{% comment %}
  PC product-list layout — optional right-side ad slot.

  Accepts:
    ad_image_filename — custom image filename
    ad_url            — url setting (optional)
    placeholder_img   — fallback data URI
{% endcomment %}

{% assign ad_link = ad_url | strip %}

<aside class="content-list-ad{% if ad_image_filename == blank %} content-list-ad--empty{% endif %}"{% if ad_image_filename == blank %} aria-hidden="true"{% else %} aria-label="Promotion"{% endif %}>
  {% if ad_image_filename != blank %}
    {% assign ad_img_src = ad_image_filename | file_img_url: '400x' %}
    {% if ad_link != blank %}
      <a href="{{ ad_link }}" class="content-list-ad-link">
        <img
          src="{{ ad_img_src }}"
          alt=""
          width="200"
          height="350"
          loading="lazy"
        >
      </a>
    {% else %}
      <div class="content-list-ad-link">
        <img
          src="{{ ad_img_src }}"
          alt=""
          width="200"
          height="350"
          loading="lazy"
        >
      </div>
    {% endif %}
  {% endif %}
</aside>
